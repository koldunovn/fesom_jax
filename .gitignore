# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ipynb_checkpoints/
.mypy_cache/
.ruff_cache/

# --- Virtual envs (the project env lives in mambaforge/envs, not here) ---
.venv/
venv/
env/

# --- JAX persistent compilation cache ---
.jax_cache/
jax_cache/

# --- Editors / OS ---
.vscode/
.idea/
*.swp
.DS_Store

# --- Claude Code agent state (per-machine memory/config; never project content) ---
.claude/

# --- Large / regenerated reference data ---
# Mesh exports (Task 0.3) and NetCDF snapshots are reproducible from the C/Fortran
# side; keep them out of git. Small per-substep probe dumps under
# fesom_jax/tests/fixtures/ ARE committed (they are tiny and are the test oracle).
*.npz
*.nc
*.npy
!fesom_jax/tests/fixtures/**
# The pi mesh (5 MB) ships WITH the package — it is what makes `pip install fesom-jax`
# runnable with no external data (examples/01_pi_quickstart.ipynb).
!fesom_jax/data/**

# --- C-exported mesh + other regenerated reference data ---
# Large artifacts live on /work (gitignored); `data` is a symlink to
# /work/ab0995/a270088/port_jax/data. Match BOTH the dir and the symlink.
/data
/data/

# --- SLURM job outputs ---
scripts/*.out
slurm-*.out
fullsuite.log

# --- A7 adjoint-window sweep artifacts (regenerated by the sbatch) ---
scripts/*.jsonl
scripts/*.png
